{
  "datasets": [
    {
      "name": "gold_anomalies",
      "displayName": "Live Gold Anomalies",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  ml_workshop.brewery.gold_anomalies"
      ]
    },
    {
      "name": "chiller_drift",
      "displayName": "Glycol Chiller Return Temp",
      "queryLines": [
        "SELECT\n",
        "  reading_ts,\n",
        "  value\n",
        "FROM\n",
        "  ml_workshop.brewery.silver_readings\n",
        "WHERE\n",
        "  tag_id = 'GLY.GLY01.RETURN_TEMP'\n",
        "ORDER BY\n",
        "  reading_ts"
      ]
    },
    {
      "name": "recent_anomalies",
      "displayName": "Recent Anomalies (Top 20)",
      "queryLines": [
        "SELECT\n",
        "  reading_ts,\n",
        "  tag_id,\n",
        "  asset_id,\n",
        "  area,\n",
        "  value,\n",
        "  crit_threshold,\n",
        "  zscore,\n",
        "  detect_reason\n",
        "FROM\n",
        "  ml_workshop.brewery.gold_anomalies\n",
        "ORDER BY\n",
        "  reading_ts DESC\n",
        "LIMIT 20"
      ]
    }
  ],
  "pages": [
    {
      "name": "5799bb86",
      "displayName": "Page 1",
      "layout": [
        {
          "widget": {
            "name": "anomaly_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_anomalies",
                  "fields": [
                    {
                      "name": "reading_ts",
                      "expression": "`reading_ts`"
                    },
                    {
                      "name": "count(*)",
                      "expression": "COUNT(`*`)"
                    }
                  ],
                  "disaggregated": false,
                  "orders": [
                    {
                      "direction": "DESC",
                      "expression": "`reading_ts`"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Total Anomalies Detected",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "count(*)"
                },
                "period": {
                  "fieldName": "reading_ts"
                }
              },
              "data": {
                "queryName": "main_query"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 4
          }
        },
        {
