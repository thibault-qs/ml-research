                  "datasetName": "gold_anomalies",
                  "fields": [
                    {
                      "name": "hourly(reading_ts)",
                      "expression": "DATE_TRUNC(\"HOUR\", `reading_ts`)"
                    },
                    {
                      "name": "count(*)",
                      "expression": "COUNT(`*`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
